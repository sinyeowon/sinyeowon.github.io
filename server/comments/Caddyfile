{$COMMENTS_DOMAIN} {
  encode gzip zstd

  handle /web/iframe.html {
    root * /srv/remark-custom
    rewrite * /iframe.html
    file_server
  }

  handle /web/remark.css {
    root * /srv/remark-custom
    rewrite * /remark.css
    file_server
  }

  handle /web/ko.mjs {
    root * /srv/remark-custom
    rewrite * /ko.mjs
    file_server
  }

  handle /web-orig/* {
    uri replace /web-orig /web
    reverse_proxy remark42:8080
  }

  @remark_web path /web/*
  header @remark_web Cache-Control "no-store, no-cache, must-revalidate, max-age=0"

  @stats_api path /api/likes /api/likes/* /api/views /api/views/*
  reverse_proxy @stats_api likes-api:8090

  reverse_proxy remark42:8080
}
